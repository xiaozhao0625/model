# P13 Web Console tunnel mode example.
# Copy this file to .env.tunnel.local and edit your current tunnel domain.
# Do NOT commit .env.tunnel.local.

WEB_CONSOLE_HOST=0.0.0.0
WEB_CONSOLE_PORT=5173

# Replace ha36b5f6f.natappfree.cc with your current natapp/frp/ngrok domain.
WEB_CONSOLE_ALLOWED_HOSTS=ha36b5f6f.natappfree.cc,192.168.1.18,localhost

# Master API runs on M0. Browsers should call /api; Vite proxies it to this target.
WEB_CONSOLE_API_PROXY_TARGET=http://127.0.0.1:8000
VITE_API_BASE_URL=/api

# Optional HMR settings for tunnel mode.
# If the page and API work but Vite websocket reports errors, uncomment and adjust:
# WEB_CONSOLE_HMR_HOST=ha36b5f6f.natappfree.cc
# WEB_CONSOLE_HMR_CLIENT_PORT=80
# WEB_CONSOLE_HMR_PROTOCOL=ws
