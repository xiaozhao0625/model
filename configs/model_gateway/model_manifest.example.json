{
  "manifest_name": "p11_model_runtime_boundaries",
  "model_root": "models",
  "notes": "Example only. P11 does not download models and does not require local model files to exist. Heavy models are on-demand; PC Game Worker must not keep large models resident.",
  "models": [
    {
      "model_id": "ui_tars",
      "provider_type": "ui_tars",
      "display_name": "UI-TARS",
      "target_machine": "M0",
      "local_path": "models/ui_tars",
      "enabled_by_default": false,
      "load_mode": "on_demand",
      "gpu_required": true,
      "vram_budget_gb": 12,
      "health_check_mode": "expected_files",
      "notes": "Primary GUI agent and low-frequency decision provider. Prefer quantized or on-demand loading on M0/W3. Do not keep resident on PC Game Worker.",
      "expected_files": ["config.json"],
      "download": {
        "source": "manual",
        "url_or_hint": "Place UI-TARS model files under MODEL_ROOT/ui_tars after architecture approval.",
        "requires_network": true
      },
      "runtime": {
        "provider_module": "ui_tars_provider",
        "max_loaded_instances": 1,
        "cpu_fallback": false
      }
    },
    {
      "model_id": "showui",
      "provider_type": "showui",
      "display_name": "ShowUI",
      "target_machine": "W2",
