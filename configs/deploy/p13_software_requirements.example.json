        "verify_command": "redis-cli ping"
      },
      {
        "name": "Node.js",
        "severity": "required",
        "official_url": "https://nodejs.org/en/download",
        "install_hint": "Install Node.js LTS.",
        "verify_command": "node --version"
      }
    ],
    "W1": [
      {
        "name": "OBS Studio",
        "severity": "required",
        "official_url": "https://obsproject.com/download",
