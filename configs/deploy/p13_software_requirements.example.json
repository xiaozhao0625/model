  "software": {
    "common": [
      {
        "name": "Python",
        "severity": "required",
        "official_url": "https://www.python.org/downloads/",
        "install_hint": "Install Python 3.11+ and enable Add python.exe to PATH.",
        "verify_command": "python --version"
      },
      {
        "name": "Git",
        "severity": "required",
        "official_url": "https://git-scm.com/install/windows",
        "install_hint": "Install Git for Windows.",
        "verify_command": "git --version"
      },
      {
        "name": "NVIDIA Driver",
        "severity": "optional",
        "official_url": "https://www.nvidia.com/en-us/geforce/drivers/",
        "install_hint": "Install the official NVIDIA driver for the local GPU.",
        "verify_command": "nvidia-smi"
      }
    ],
    "M0": [
      {
        "name": "PostgreSQL psql",
        "severity": "required",
        "official_url": "https://www.postgresql.org/download/windows/",
