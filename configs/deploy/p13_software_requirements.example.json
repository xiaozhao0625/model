    "W2": [
      {
        "name": "Playwright Python package",
        "severity": "required",
        "official_url": "https://playwright.dev/python/docs/intro",
        "install_hint": "pip install playwright",
        "verify_command": "python -m playwright --version"
      },
      {
        "name": "Playwright browsers",
        "severity": "required",
        "official_url": "https://playwright.dev/python/docs/browsers",
        "install_hint": "python -m playwright install",
        "verify_command": "python -m playwright install --dry-run"
      },
      {
        "name": "pywinauto",
        "severity": "required",
        "official_url": "https://pypi.org/project/pywinauto/",
        "install_hint": "pip install pywinauto",
        "verify_command": "python -c \"import pywinauto\""
      },
      {
        "name": "mss",
        "severity": "required",
        "official_url": "https://pypi.org/project/mss/",
