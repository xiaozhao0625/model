{
  "topology_name": "four_node_prod",
  "mode": "production",
  "description": "Four-machine production topology for master services, model gateway, and dedicated workers.",
  "master": {
    "service_name": "master-api",
    "machine_id": "M0",
    "host": "m0.internal",
    "port": 8000,
    "database_url_env": "DATABASE_URL",
    "redis_url_env": "REDIS_URL"
  },
  "model_gateway": {
    "service_name": "model-gateway",
    "machine_id": "M0",
    "host": "m0.internal",
    "port": 8100,
    "mode": "provider_ready",
    "model_manifest": "configs/model_gateway/model_manifest.example.json"
  },
  "machines": [
    {
      "machine_id": "M0",
      "machine_name": "master-rtx-5060ti",
      "role": "master_model_gateway",
      "gpu_name": "RTX 5060 Ti 16GB",
      "services": [
        "master-api",
        "postgresql",
        "redis",
        "model-gateway"
      ],
      "data_root": "runs/prod/m0",
      "model_root": "models"
    },
    {
      "machine_id": "W1",
      "machine_name": "worker-pc-game-rtx-3060",
      "role": "pc_game_worker",
      "gpu_name": "RTX 3060 12GB",
      "services": [
        "worker-pc-game"
      ],
      "data_root": "runs/prod/w1",
      "model_root": "models"
    },
    {
      "machine_id": "W2",
      "machine_name": "worker-pc-app-web-rtx-3060",
      "role": "pc_app_web_worker",
      "gpu_name": "RTX 3060 12GB",
      "services": [
        "worker-pc-app",
        "worker-web"
      ],
      "data_root": "runs/prod/w2",
      "model_root": "models"
    },
    {
      "machine_id": "W3",
      "machine_name": "worker-android-rtx-3060",
      "role": "android_worker",
      "gpu_name": "RTX 3060 12GB",
      "services": [
        "worker-android"
      ],
      "data_root": "runs/prod/w3",
      "model_root": "models"
    }
  ],
  "workers": [
    {
      "worker_id": "worker_pc_game_w1",
      "worker_type": "pc_game",
      "machine_id": "W1",
      "capabilities": [
        "capture_high",
        "behavior_pack",
        "obs_capture",
        "ffmpeg_extract"
      ],
      "data_root": "runs/prod/w1/pc_game",
      "master_url": "http://m0.internal:8000",
      "model_gateway_url": "http://m0.internal:8100"
    },
    {
      "worker_id": "worker_pc_app_web_w2",
      "worker_type": "pc_app_web",
      "machine_id": "W2",
      "capabilities": [
        "capture_low",
        "playwright",
        "pywinauto",
        "model_gateway"
      ],
      "data_root": "runs/prod/w2/pc_app_web",
      "master_url": "http://m0.internal:8000",
      "model_gateway_url": "http://m0.internal:8100"
    },
    {
      "worker_id": "worker_android_w3",
      "worker_type": "android",
      "machine_id": "W3",
      "capabilities": [
        "capture_low",
        "adb",
        "model_gateway"
      ],
      "data_root": "runs/prod/w3/android",
      "master_url": "http://m0.internal:8000",
      "model_gateway_url": "http://m0.internal:8100"
    }
  ]
}
